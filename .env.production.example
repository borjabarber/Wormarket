# Wormarket production variables template.
# Do not paste real values in this file. Configure real values in Vercel/Supabase dashboards.

# Runtime
NODE_ENV=production

# Public frontend/API URL.
# Replace after Vercel assigns the final production URL.
NEXT_PUBLIC_API_URL=https://your-vercel-project.vercel.app/api
FRONTEND_URL=https://your-vercel-project.vercel.app

# Supabase PostgreSQL.
# DATABASE_URL is used by the runtime API/Prisma code.
# DIRECT_URL is used by Prisma migration commands when connecting to Supabase.
DATABASE_URL=
DIRECT_URL=

# JWT secrets.
# Generate two different 64-byte hex values and store them only in Vercel environment variables.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Storage.
# Supabase Storage is planned for production uploads, but the adapter is implemented in a later task.
STORAGE_DRIVER=supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=wormarket-listing-images
